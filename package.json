{
  "name": "instruckt",
  "version": "0.4.32",
  "description": "Visual feedback tool for AI coding agents — framework-agnostic, Livewire-first",
  "type": "module",
  "license": "MIT",
  "author": "instruckt",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshcirre/instruckt"
  },
  "main": "dist/instruckt.cjs.js",
  "module": "dist/instruckt.esm.js",
  "types": "dist/instruckt.d.ts",
  "exports": {
    ".": {
      "types": "./dist/instruckt.d.ts",
      "require": "./dist/instruckt.cjs.js",
      "import": "./dist/instruckt.esm.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "require": "./dist/vite.cjs.js",
      "import": "./dist/vite.esm.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "oxlint src/",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "oxlint": "^1.51.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "element-source": "^0.0.4",
    "modern-screenshot": "^4.6.8"
  }
}
